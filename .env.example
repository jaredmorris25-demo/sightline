# Sightline — Environment Variables
# Copy this file to .env and fill in values for local development.
# NEVER commit .env or any file containing real values.

# Database
DATABASE_URL=
DATABASE_URL_SYNC=

# Auth
AUTH0_DOMAIN=
AUTH0_API_AUDIENCE=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Azure Storage
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_SIGHTINGS=
AZURE_STORAGE_CONTAINER_INGEST=
AZURE_CDN_ENDPOINT=

# Azure Service Bus
AZURE_SERVICEBUS_CONNECTION_STRING=
AZURE_SERVICEBUS_QUEUE_MEDIA=

# Azure AI Search
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_SPECIES=
AZURE_SEARCH_INDEX_SIGHTINGS=

# App
ENVIRONMENT=
LOG_LEVEL=
CORS_ORIGINS=

# Local dev — Docker Compose database credentials
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# pgAdmin
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=
